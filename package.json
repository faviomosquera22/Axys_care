{
  "name": "axyscare",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "corepack pnpm --filter @axyscare/web dev",
    "dev:mobile": "corepack pnpm --filter @axyscare/mobile dev",
    "mobile:ios": "corepack pnpm --filter @axyscare/mobile ios:device",
    "mobile:ios:release": "corepack pnpm --filter @axyscare/mobile ios:release:device",
    "mobile:start:dev-client": "corepack pnpm --filter @axyscare/mobile start:dev-client",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  }
}
