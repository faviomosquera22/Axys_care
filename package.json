  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3"
  }
}
